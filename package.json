{
  "name": "aku",
  "version": "1.0.0",
  "description": "CRM für Akquiseanrufe",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "start": "vite build && electron .",
    "electron": "electron .",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.aku.crm",
    "productName": "Aku CRM",
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.icns",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "eneshome-arch",
      "repo": "aku-crm"
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "electron-store": "^8.2.0",
    "lucide-react": "^1.21.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  }
}
